# =========================================================
# seed/ — standalone test-data seeder
# Copy to `seed/.env` (only needed when running without a parent project's .env).
# Process env vars always win over values set here.
# =========================================================

# --- Target database -------------------------------------
# The MySQL the seeder writes into. Defaults aim at the host-exposed MySQL of
# the parent project (127.0.0.1:${MYSQL_PORT}). Set SEED_DB_HOST/_PORT when
# running from inside Docker (e.g. SEED_DB_HOST=mysql-test, SEED_DB_PORT=3306).
MYSQL_DATABASE=testdb
MYSQL_USER=tester
MYSQL_PASSWORD=change-me-mysql-password
MYSQL_PORT=3307

# --- Optional overrides ----------------------------------
# Full SQLAlchemy URL — when set, every MYSQL_* var above is ignored.
# SEED_DATABASE_URL=mysql+pymysql://user:pass@host:3306/dbname

# Override the DB host/port without touching MYSQL_*.
# SEED_DB_HOST=127.0.0.1
# SEED_DB_PORT=3307

# Point at a different config preset.
# SEED_CONFIG_PATH=/abs/path/to/config.yml

# Point at a different env file (skips the auto-discovery).
# SEED_ENV_FILE=/abs/path/to/another.env
