# =========================================================
# Superset stack config. Consumed by superset/docker/docker-compose.yml
# (both for ${VAR} interpolation and as `env_file` for the containers).
# Shared infra config (MYSQL_*) lives in the project-root .env.
#
# Copy this file to `superset/.env` and change every `change-me-...` value.
# =========================================================

# --- Flask / Superset secret key ---
# Generate one: `openssl rand -base64 42`  (PowerShell equivalent:
#   [Convert]::ToBase64String((1..42 | % {Get-Random -Max 256}))  )
SUPERSET_SECRET_KEY=change-me-to-a-long-random-string

# --- Admin user created on first `up` ---
ADMIN_USERNAME=admin
ADMIN_FIRSTNAME=Admin
ADMIN_LASTNAME=Superset
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password

# --- Postgres (Superset metadata DB) ---
POSTGRES_DB=superset
POSTGRES_USER=superset
POSTGRES_PASSWORD=change-me-postgres-password

# --- App ---
SUPERSET_PORT=8088
# `yes` loads the demo dashboards (handy while learning). Use `no` in production.
SUPERSET_LOAD_EXAMPLES=no
