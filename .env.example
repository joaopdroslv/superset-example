# =========================================================
# Shared infrastructure config (root .env).
# Variables here are used by multiple domains — currently the test MySQL,
# which is a datasource for Superset AND the target for the seeder.
#
# Copy this file to `.env` and change every `change-me-...` value.
# Domain-specific secrets live next to each domain:
#   - superset/.env.example  →  Superset stack
# =========================================================

# --- MySQL test database (used by docker/docker-compose.tests.yml and seed/) ---
# In-cluster hostname is `mysql-test`. Inside Superset use:
#   mysql+pymysql://${MYSQL_USER}:${MYSQL_PASSWORD}@mysql-test:3306/${MYSQL_DATABASE}
MYSQL_ROOT_PASSWORD=change-me-mysql-root-password
MYSQL_DATABASE=testdb
MYSQL_USER=tester
MYSQL_PASSWORD=change-me-mysql-password
# Host port mapping — use 3307 to avoid clashing with a local MySQL on 3306.
MYSQL_PORT=3307
